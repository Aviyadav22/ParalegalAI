# Production Environment Configuration for ParalegalAI
# Multi-Instance ChromaDB Setup
# Copy this file to .env.production and update with your actual values

# ===========================================
# VECTOR DATABASE CONFIGURATION
# ===========================================
VECTOR_DB=chroma-multi

# Multi-Instance ChromaDB Endpoints
# Comma-separated list of ChromaDB node endpoints
CHROMA_ENDPOINTS=http://chromadb-1:8000,http://chromadb-2:8000,http://chromadb-3:8000

# Load Balancer Configuration
CHROMA_LOAD_BALANCER=http://chromadb-lb:80

# Load Balancing Strategy
CHROMA_STRATEGY=round-robin

# ChromaDB Authentication (if required)
# CHROMA_API_HEADER=X-Api-Key
# CHROMA_API_KEY=your-chromadb-api-key-here

# ===========================================
# LLM CONFIGURATION
# ===========================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_LLM_MODEL_PREF=gemini-2.0-flash-lite

# ===========================================
# EMBEDDING CONFIGURATION
# ===========================================
EMBEDDING_ENGINE=gemini
EMBEDDING_MODEL_PREF=embedding-001
DISABLE_NATIVE_EMBEDDINGS=true
FORCE_EMBEDDING_PROVIDER=gemini

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NODE_ENV=production
MULTI_USER_MODE=false
DISABLE_TELEMETRY=true

# JWT Configuration (Generate strong secrets for production)
JWT_SECRET=your-strong-jwt-secret-here
JWT_EXPIRY=24h

# Encryption Keys (Generate strong keys for production)
SIG_KEY=your-strong-signature-key-here
SIG_SALT=your-strong-salt-here

# CORS Configuration (Restrict for production)
CORS_ORIGINS=https://yourdomain.com
CORS_CREDENTIALS=true

# ===========================================
# STORAGE CONFIGURATION
# ===========================================
STORAGE_DIR=/app/server/storage
ANYTHING_LLM_RUNTIME=docker

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# Maximum concurrent connections per ChromaDB node
CHROMA_MAX_CONNECTIONS=50

# Connection timeout in milliseconds
CHROMA_CONNECTION_TIMEOUT=10000

# Request timeout in milliseconds
CHROMA_REQUEST_TIMEOUT=30000

# Health check interval in milliseconds
CHROMA_HEALTH_CHECK_INTERVAL=30000

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Enable detailed logging for multi-instance operations
CHROMA_DEBUG_LOGGING=false

# Log level for ChromaDB operations
CHROMA_LOG_LEVEL=warn

# ===========================================
# BACKUP AND RECOVERY
# ===========================================
# Enable automatic backup of ChromaDB data
CHROMA_AUTO_BACKUP=true

# Backup interval in hours
CHROMA_BACKUP_INTERVAL=24

# Backup retention days
CHROMA_BACKUP_RETENTION=30

# ===========================================
# MONITORING AND METRICS
# ===========================================
# Enable metrics collection
CHROMA_ENABLE_METRICS=true

# Metrics collection interval in seconds
CHROMA_METRICS_INTERVAL=60

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Enable HTTPS
HTTPS_ENABLED=true
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session configuration
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Use PostgreSQL for production
DATABASE_URL=postgresql://username:password@localhost:5432/paralegal_ai

# ===========================================
# REDIS CONFIGURATION (for caching)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# ===========================================
# MONITORING AND ALERTING
# ===========================================
# Sentry for error tracking
SENTRY_DSN=your-sentry-dsn-here

# Health check endpoints
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
# S3 backup configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-backup-bucket

# Backup encryption
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
