# Multi-Instance ChromaDB Configuration for ParalegalAI
# Copy this file to .env and modify as needed

# ===========================================
# VECTOR DATABASE CONFIGURATION
# ===========================================
VECTOR_DB=chroma-multi

# Multi-Instance ChromaDB Endpoints
# Comma-separated list of ChromaDB node endpoints
CHROMA_ENDPOINTS=http://localhost:8001,http://localhost:8002,http://localhost:8003

# Load Balancer Configuration (optional)
CHROMA_LOAD_BALANCER=http://chromadb-lb:80

# Load Balancing Strategy
# Options: round-robin, random, least-connections
CHROMA_STRATEGY=round-robin

# Node-specific configurations (for direct access)
CHROMA_NODE_1_ENDPOINT=http://chromadb-1:8000
CHROMA_NODE_2_ENDPOINT=http://chromadb-2:8000
CHROMA_NODE_3_ENDPOINT=http://chromadb-3:8000

# ChromaDB Authentication (if required)
# CHROMA_API_HEADER=X-Api-Key
# CHROMA_API_KEY=your-api-key-here

# ===========================================
# LLM CONFIGURATION
# ===========================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyAt4lxLI6VUeuwrDrYp_5zoMH4BswBl2pE

# ===========================================
# EMBEDDING CONFIGURATION
# ===========================================
EMBEDDING_ENGINE=gemini
EMBEDDING_MODEL_PREF=embedding-001
DISABLE_NATIVE_EMBEDDINGS=true
FORCE_EMBEDDING_PROVIDER=gemini

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NODE_ENV=production
MULTI_USER_MODE=false
DISABLE_TELEMETRY=false

# JWT Configuration
JWT_SECRET=mu8aL6T9Lqz1XWeQrnplGcY/CEpS207NBJtTJXqeX4s=
JWT_EXPIRY=24h

# Encryption Keys
SIG_KEY=1Y2ua8QGdUTDdoy4OCpIew==
SIG_SALT=1Y2ua8QGdUTDdoy4OCpIew==

# CORS Configuration
CORS_ORIGINS=*
CORS_CREDENTIALS=false

# ===========================================
# STORAGE CONFIGURATION
# ===========================================
STORAGE_DIR=/app/server/storage
ANYTHING_LLM_RUNTIME=docker

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# Maximum concurrent connections per ChromaDB node
CHROMA_MAX_CONNECTIONS=10

# Connection timeout in milliseconds
CHROMA_CONNECTION_TIMEOUT=30000

# Request timeout in milliseconds
CHROMA_REQUEST_TIMEOUT=60000

# Health check interval in milliseconds
CHROMA_HEALTH_CHECK_INTERVAL=30000

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Enable detailed logging for multi-instance operations
CHROMA_DEBUG_LOGGING=true

# Log level for ChromaDB operations
# Options: error, warn, info, debug
CHROMA_LOG_LEVEL=info

# ===========================================
# BACKUP AND RECOVERY
# ===========================================
# Enable automatic backup of ChromaDB data
CHROMA_AUTO_BACKUP=true

# Backup interval in hours
CHROMA_BACKUP_INTERVAL=24

# Backup retention days
CHROMA_BACKUP_RETENTION=7

# ===========================================
# MONITORING AND METRICS
# ===========================================
# Enable metrics collection
CHROMA_ENABLE_METRICS=true

# Metrics collection interval in seconds
CHROMA_METRICS_INTERVAL=60

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# For local development, you can use these endpoints:
# CHROMA_LOAD_BALANCER=http://localhost:8000

# ===========================================
# PRODUCTION CONFIGURATION
# ===========================================
# For production deployment, use these settings:
# CHROMA_LOAD_BALANCER=http://chromadb-lb:80
# CHROMA_STRATEGY=round-robin
# CHROMA_MAX_CONNECTIONS=50
# CHROMA_CONNECTION_TIMEOUT=10000
# CHROMA_REQUEST_TIMEOUT=30000


GEMINI_LLM_MODEL_PREF=gemini-2.0-flash-lite
