# Docker Environment Configuration for ParalegalAI
# Copy this file to .env and update the values as needed

# Application Settings
NODE_ENV=production
STORAGE_DIR=/app/server/storage
ANYTHING_LLM_RUNTIME=docker

# Server Configuration
SERVER_PORT=3001

# Database Configuration (SQLite by default)
DATABASE_URL="file:./storage/anythingllm.db"

# JWT Configuration
JWT_EXPIRY=24h

# Multi-user mode
MULTI_USER_MODE=false

# Vector Database
VECTOR_DB=lancedb

# LLM Provider Configuration
LLM_PROVIDER=openai
OPEN_AI_KEY=your_openai_api_key_here
OPEN_MODEL_PREF=gpt-4

# Alternative LLM Providers (uncomment and configure as needed)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL_PREF=claude-3-sonnet-20240229

# Embedding Configuration
EMBEDDING_MODEL_PREF=text-embedding-3-small

# Security (will be auto-generated if not provided)
# SIG_KEY=
# SIG_SALT=

# Telemetry
DISABLE_TELEMETRY=false

# Community Hub
COMMUNITY_HUB_BUNDLE_DOWNLOADS_ENABLED=true

# Collector Configuration
COLLECTOR_ALLOW_ANY_IP=true

